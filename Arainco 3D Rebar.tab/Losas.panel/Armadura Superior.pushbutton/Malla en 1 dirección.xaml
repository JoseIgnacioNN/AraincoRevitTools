<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Formulario"
        Height="418"
        Width="340"
        Background="#FFF7F7F7"
        FontFamily="Segoe UI"
        FontSize="13"
        WindowStartupLocation="Manual"
        ResizeMode="NoResize"
        Topmost="True"
        ShowInTaskbar="False">
  <Grid Margin="10">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <StackPanel Grid.Row="0" Orientation="Vertical" HorizontalAlignment="Stretch" Margin="0,2,0,6">
      <Image x:Name="imgLogo"
             Width="260"
             Height="70"
             Stretch="Uniform"
             HorizontalAlignment="Center"
             VerticalAlignment="Center"/>
      <TextBlock HorizontalAlignment="Center"
                 Margin="0,6,0,0"
                 FontSize="19"
                 FontWeight="Bold"
                 Foreground="#FF1F93C9"
                 TextAlignment="Center">
        <Run Text="Armadura Superior"/>
        <LineBreak/>
        <Run Text="Losas y Fundaciones"/>
      </TextBlock>
      
      <!-- Rutina de armado -->
      <Border BorderBrush="#FFD0D0D0" BorderThickness="1" CornerRadius="10" Padding="12" Margin="0,10,0,0" Background="#FFFFFFFF">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
          </Grid.RowDefinitions>

          <TextBlock Grid.Row="0" Text="Rutina de armado" FontWeight="Bold" Foreground="#FF1F93C9" Margin="0,0,0,6" FontSize="14"/>
          <ComboBox x:Name="cmbCambioRutina" Grid.Row="1" SelectionChanged="CmbCambioRutina_SelectionChanged" Height="28" Padding="6,2" VerticalContentAlignment="Center" Background="#FFFFFFFF" Foreground="#FF4F4F4F" BorderBrush="#FFD0D0D0" BorderThickness="1"/>
        </Grid>
      </Border>
    </StackPanel>


    <!-- Diámetro de barra -->
    <Border Grid.Row="2" BorderBrush="#FFD0D0D0" BorderThickness="1" CornerRadius="10" Padding="12" Margin="0,0,0,6" Background="#FFFFFFFF">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto"/>
          <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Column="0" Grid.Row="0" Text="Diámetro de barra:" VerticalAlignment="Center" Foreground="#FF4F4F4F" Margin="0,0,5,6" FontSize="13"/>
        <ComboBox x:Name="cmbRebar"
                  Grid.Column="1" Grid.Row="0"
                  Background="#FFFFFFFF"
                  Foreground="#FF4F4F4F"
                  BorderBrush="#FF1F93C9"
                  BorderThickness="1"
                  Padding="6,2"
                  HorizontalContentAlignment="Center"
                  VerticalContentAlignment="Center"
                  VerticalAlignment="Center"
                  MinHeight="28"/>

        <TextBlock Grid.Column="0" Grid.Row="1" Text="Espaciamiento [mm]:" VerticalAlignment="Center" Foreground="#FF4F4F4F" Margin="0,6,5,0" FontSize="13"/>
        <TextBox x:Name="txtEspaciamiento"
                 Grid.Column="1" Grid.Row="1"
                 Margin="0,5,0,0"
                 Background="#FFFFFFFF"
                 Foreground="#FF4F4F4F"
                 BorderBrush="#FF1F93C9"
                 BorderThickness="1"
                 Padding="6,2"
                 HorizontalContentAlignment="Center"
                 VerticalContentAlignment="Center"
                 TextAlignment="Center"
                 VerticalAlignment="Center"/>
      </Grid>
    </Border>

    <!-- Botón aplicar -->
    <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,7,0,0">
      <Button x:Name="btnAplicar"
              Content="Aplicar vano y recorrido"
              Width="180"
              Height="38"
              Background="#FF1F93C9"
              Foreground="White"
              BorderBrush="#FF1F93C9"
              BorderThickness="1"
              FontWeight="Bold"
              Click="AplicarClick"/>
    </StackPanel>
  </Grid>
</Window>

