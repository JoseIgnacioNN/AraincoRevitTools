<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Formulario"
        Height="529"
        Width="340"
        Background="#FFF7F7F7"
        FontFamily="Segoe UI"
        FontSize="13"
        WindowStartupLocation="Manual"
        ResizeMode="NoResize"
        Topmost="True"
        ShowInTaskbar="False">
  <Grid Margin="10">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <StackPanel Grid.Row="0" Orientation="Vertical" HorizontalAlignment="Center" Margin="0,2,0,12">
      <Image x:Name="imgLogo"
             Width="260"
             Height="70"
             Stretch="Uniform"
             HorizontalAlignment="Center"
             VerticalAlignment="Center"/>
      <TextBlock HorizontalAlignment="Center"
                 Margin="0,6,0,0"
                 FontSize="19"
                 FontWeight="Bold"
                 Foreground="#FF1F93C9"
                 TextAlignment="Center">
        <Run Text="Armadura Superior"/>
        <LineBreak/>
        <Run Text="Losas y Fundaciones"/>
      </TextBlock>
    </StackPanel>

    <!-- Vano 1 -->
    <Border Grid.Row="1" BorderBrush="#FFD0D0D0" BorderThickness="1" CornerRadius="10" Padding="12" Margin="0,0,0,6" Background="#FFFFFFFF">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto"/>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="Auto"/>
          <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Column="0" Grid.Row="0" Text="Vano 1" FontWeight="Bold" Foreground="#FF1F93C9" Margin="0,0,10,6" FontSize="14"/>
        <Button x:Name="btnVano1"
                Grid.Column="1" Grid.Row="0" Grid.ColumnSpan="3"
                Content="Seleccionar"
                Height="28"
                HorizontalAlignment="Stretch"
                Margin="0,0,0,6"
                Background="#FF1F93C9"
                Foreground="White"
                BorderBrush="#FF1F93C9"
                BorderThickness="1"
                FontWeight="Bold"
                Click="Vano1Click"/>

        <TextBlock Grid.Column="0" Grid.Row="1" Text="Largo [mm]:" VerticalAlignment="Center" Foreground="#FF4F4F4F" Margin="0,0,5,0"/>
        <TextBox x:Name="txtLargo1"
                 Grid.Column="1" Grid.Row="1"
                 IsReadOnly="True"
                 Background="#FFF0F0F0"
                 Foreground="#FF4F4F4F"
                 BorderBrush="#FF1F93C9"
                 BorderThickness="1"
                 Padding="6,2"
                 Margin="0,0,5,0"
                 HorizontalContentAlignment="Center"
                 VerticalContentAlignment="Center"
                 TextAlignment="Center"
                 VerticalAlignment="Center"/>

        <TextBlock Grid.Column="2" Grid.Row="1" Text="L1 [mm]:" VerticalAlignment="Center" Foreground="#FF4F4F4F" Margin="4,0,2,0"/>
        <TextBox x:Name="txtL1"
                 Grid.Column="3" Grid.Row="1"
                 IsReadOnly="False"
                 Background="#FFFFFFFF"
                 Foreground="#FF4F4F4F"
                 BorderBrush="#FF1F93C9"
                 BorderThickness="1"
                 Padding="6,2"
                 Margin="2,0,0,0"
                 HorizontalContentAlignment="Center"
                 VerticalContentAlignment="Center"
                 TextAlignment="Center"
                 VerticalAlignment="Center"/>
      </Grid>
    </Border>

    <!-- Vano 2 -->
    <Border Grid.Row="2" BorderBrush="#FFD0D0D0" BorderThickness="1" CornerRadius="10" Padding="12" Margin="0,0,0,6" Background="#FFFFFFFF">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto"/>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="Auto"/>
          <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Column="0" Grid.Row="0" Text="Vano 2" FontWeight="Bold" Foreground="#FF1F93C9" Margin="0,0,10,6" FontSize="14"/>
        <Button x:Name="btnVano2"
                Grid.Column="1" Grid.Row="0" Grid.ColumnSpan="3"
                Content="Seleccionar"
                Height="28"
                HorizontalAlignment="Stretch"
                Margin="0,0,0,6"
                Background="#FF1F93C9"
                Foreground="White"
                BorderBrush="#FF1F93C9"
                BorderThickness="1"
                FontWeight="Bold"
                Click="Vano2Click"/>

        <TextBlock Grid.Column="0" Grid.Row="1" Text="Largo [mm]:" VerticalAlignment="Center" Foreground="#FF4F4F4F" Margin="0,0,5,0"/>
        <TextBox x:Name="txtLargo2"
                 Grid.Column="1" Grid.Row="1"
                 IsReadOnly="True"
                 Background="#FFF0F0F0"
                 Foreground="#FF4F4F4F"
                 BorderBrush="#FF1F93C9"
                 BorderThickness="1"
                 Padding="6,2"
                 Margin="0,0,5,0"
                 HorizontalContentAlignment="Center"
                 VerticalContentAlignment="Center"
                 TextAlignment="Center"
                 VerticalAlignment="Center"/>

        <TextBlock Grid.Column="2" Grid.Row="1" Text="L2 [mm]:" VerticalAlignment="Center" Foreground="#FF4F4F4F" Margin="4,0,2,0"/>
        <TextBox x:Name="txtL2"
                 Grid.Column="3" Grid.Row="1"
                 IsReadOnly="False"
                 Background="#FFFFFFFF"
                 Foreground="#FF4F4F4F"
                 BorderBrush="#FF1F93C9"
                 BorderThickness="1"
                 Padding="6,2"
                 Margin="2,0,0,0"
                 HorizontalContentAlignment="Center"
                 VerticalContentAlignment="Center"
                 TextAlignment="Center"
                 VerticalAlignment="Center"/>
      </Grid>
    </Border>

    <!-- Diámetro de barra -->
    <Border Grid.Row="3" BorderBrush="#FFD0D0D0" BorderThickness="1" CornerRadius="10" Padding="12" Margin="0,0,0,6" Background="#FFFFFFFF">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto"/>
          <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Column="0" Grid.Row="0" Text="Diámetro de barra:" VerticalAlignment="Center" Foreground="#FF4F4F4F" Margin="0,0,5,6" FontSize="13"/>
        <ComboBox x:Name="cmbRebar"
                  Grid.Column="1" Grid.Row="0"
                  Background="#FFFFFFFF"
                  Foreground="#FF4F4F4F"
                  BorderBrush="#FF1F93C9"
                  BorderThickness="1"
                  Padding="6,2"
                  HorizontalContentAlignment="Center"
                  VerticalContentAlignment="Center"
                  VerticalAlignment="Center"
                  MinHeight="28"/>

        <TextBlock Grid.Column="0" Grid.Row="1" Text="Espaciamiento [mm]:" VerticalAlignment="Center" Foreground="#FF4F4F4F" Margin="0,6,5,0" FontSize="13"/>
        <TextBox x:Name="txtEspaciamiento"
                 Grid.Column="1" Grid.Row="1"
                 Margin="0,5,0,0"
                 Background="#FFFFFFFF"
                 Foreground="#FF4F4F4F"
                 BorderBrush="#FF1F93C9"
                 BorderThickness="1"
                 Padding="6,2"
                 HorizontalContentAlignment="Center"
                 VerticalContentAlignment="Center"
                 TextAlignment="Center"
                 VerticalAlignment="Center"/>
      </Grid>
    </Border>

    <!-- Botón aplicar -->
    <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,15,0,0">
      <Button x:Name="btnAplicar"
              Content="Aplicar recorrido"
              Width="180"
              Height="38"
              Background="#FF1F93C9"
              Foreground="White"
              BorderBrush="#FF1F93C9"
              BorderThickness="1"
              FontWeight="Bold"
              Click="AplicarClick"/>
    </StackPanel>
  </Grid>
</Window>

