<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Name="ColumnReinforcementWin"
        Title="Arainco: Armado Columnas"
        Height="430" Width="560"
        MinHeight="390" MinWidth="520"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#071018"
        FontFamily="Segoe UI"
        FontSize="12">
  <Window.Resources>
__BIMTOOLS_DARK_STYLES__
  </Window.Resources>
  <Border Background="#071018" BorderBrush="#21465C" BorderThickness="1" Padding="18">
    <Grid>
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="*"/>
        <RowDefinition Height="Auto"/>
      </Grid.RowDefinitions>

      <StackPanel Grid.Row="0" Margin="0,0,0,14">
        <TextBlock Text="Arainco: Armado Columnas" Foreground="#E8F4F8" FontSize="20" FontWeight="Bold"/>
        <TextBlock Text="Refactor enterprise modular para Revit 2024+" Foreground="#95B8CC" Margin="0,6,0,0"/>
      </StackPanel>

      <StackPanel Grid.Row="1">
        <GroupBox Header="Ejecución" Style="{StaticResource GbParams}">
          <StackPanel>
            <TextBlock Text="Esta primera fase abre el flujo modular WPF y ejecuta el motor legado para preservar resultados." Foreground="#D5EAF2" TextWrapping="Wrap" Margin="0,0,0,12"/>
            <CheckBox x:Name="UseLegacyEngineCheck" Content="Usar motor legado validado" IsChecked="True" IsEnabled="False" Foreground="#E8F4F8" Margin="0,0,0,8"/>
            <CheckBox x:Name="SplitPlanesCheck" Content="Mantener política de troceo A/B/IB" IsChecked="True" IsEnabled="False" Foreground="#E8F4F8" Margin="0,0,0,8"/>
            <CheckBox x:Name="EmbedmentCheck" Content="Mantener empotramiento tabular después del troceo" IsChecked="True" IsEnabled="False" Foreground="#E8F4F8"/>
          </StackPanel>
        </GroupBox>

        <GroupBox Header="Arquitectura" Style="{StaticResource GbParams}">
          <TextBlock Foreground="#D5EAF2" TextWrapping="Wrap"
                     Text="La UI, ViewModel, modelos, servicios, geometría pura y adapters Revit ya están separados para migrar reglas sin romper la herramienta."/>
        </GroupBox>
      </StackPanel>

      <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
        <Button x:Name="CancelButton" Content="Cancelar" Style="{StaticResource BtnSelectOutline}" MinWidth="110" Margin="0,0,10,0"/>
        <Button x:Name="RunButton" Content="Ejecutar" Style="{StaticResource BtnPrimary}" MinWidth="130"/>
      </StackPanel>
    </Grid>
  </Border>
</Window>
