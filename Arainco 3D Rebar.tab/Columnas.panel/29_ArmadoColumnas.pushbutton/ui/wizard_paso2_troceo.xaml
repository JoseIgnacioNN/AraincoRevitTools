<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Name="TroceoSchemeWin"
        Title="Arainco: Esquema de troceo de columnas"
        Height="640" Width="720"
        MinHeight="500" MinWidth="640"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        Background="#071018"
        FontFamily="Segoe UI"
        FontSize="12">
  <Window.Resources>
__BIMTOOLS_DARK_STYLES__
  </Window.Resources>
  <Border Background="#071018" Padding="18">
    <Grid>
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="*" MinHeight="180"/>
        <RowDefinition Height="Auto"/>
      </Grid.RowDefinitions>

      <StackPanel Grid.Row="0" Margin="0,0,0,12">
        <TextBlock Text="Definicion de Empalmes, Diametros y Espaciamiento de Estribos" Foreground="#E8F4F8" FontSize="18" FontWeight="Bold" TextWrapping="Wrap"/>
        <TextBlock x:Name="SubtitleText" Margin="0,6,0,0" Foreground="#95B8CC" TextWrapping="Wrap"
                   Text="Fuste, cotas y Ø longitudinal por tramo de troceo en la franja a la derecha del fuste. Ø/tipo y espaciamiento de estribos a la izquierda. «Alternar referencia»: Desde / Cada."/>
      </StackPanel>

      <Border Grid.Row="1" CornerRadius="4" Padding="12" Margin="0,0,0,12" Background="#0b1924">
        <Border Background="#050a10" CornerRadius="4" Padding="10" VerticalAlignment="Stretch">
            <Grid VerticalAlignment="Stretch">
              <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*" MinHeight="220"/>
                <RowDefinition Height="Auto"/>
              </Grid.RowDefinitions>
              <Border Grid.Row="0" Margin="0,0,0,6" HorizontalAlignment="Stretch" Background="Transparent">
                <Canvas x:Name="TroceoSchemeHeaderCanvas" Height="26" HorizontalAlignment="Center" VerticalAlignment="Top" MinHeight="22"/>
              </Border>
              <ScrollViewer x:Name="TroceoSchemeScroll" Grid.Row="1" VerticalScrollBarVisibility="Auto"
                            HorizontalScrollBarVisibility="Auto" VerticalAlignment="Stretch">
                <StackPanel x:Name="BlocksHost" VerticalAlignment="Top" MinHeight="120"/>
              </ScrollViewer>
              <Grid Grid.Row="2" Margin="0,12,0,0">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="Auto"/>
                  <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                  <TextBlock Text="Desde tramo" Foreground="#94a3b8" FontSize="11" VerticalAlignment="Center" Margin="0,0,6,0"/>
                  <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBox x:Name="TbTroceoAltStart" Width="40" MinHeight="28" Text="2" MaxLength="4"
                             Background="#0f172a" Foreground="#E8F4F8" BorderBrush="#334155" Padding="4,2"
                             VerticalContentAlignment="Center" FontSize="11"
                             ToolTip="Primer tramo del patrón (1 = base)."/>
                    <Border BorderBrush="#334155" BorderThickness="1" CornerRadius="0,4,4,0" Background="#0f172a"
                            Width="26" MinHeight="28" Margin="-1,0,0,0" VerticalAlignment="Stretch">
                      <Grid>
                        <Grid.RowDefinitions>
                          <RowDefinition Height="*"/>
                          <RowDefinition Height="1"/>
                          <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Button x:Name="BtnTroceoAltStartInc" Grid.Row="0"
                                Content="&#x25B2;" FontSize="9" Padding="0,1,0,0" Margin="0"
                                Background="Transparent" BorderThickness="0" Foreground="#94a3b8"
                                VerticalContentAlignment="Center" HorizontalContentAlignment="Center"
                                ToolTip="Más 1"/>
                        <Border Grid.Row="1" Background="#334155" Height="1"/>
                        <Button x:Name="BtnTroceoAltStartDec" Grid.Row="2"
                                Content="&#x25BC;" FontSize="9" Padding="0,0,0,1" Margin="0"
                                Background="Transparent" BorderThickness="0" Foreground="#94a3b8"
                                VerticalContentAlignment="Center" HorizontalContentAlignment="Center"
                                ToolTip="Menos 1"/>
                      </Grid>
                    </Border>
                  </StackPanel>
                  <TextBlock Text="cada" Foreground="#64748b" FontSize="11" VerticalAlignment="Center" Margin="10,0,6,0"/>
                  <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBox x:Name="TbTroceoAltStep" Width="40" MinHeight="28" Text="2" MaxLength="4"
                             Background="#0f172a" Foreground="#E8F4F8" BorderBrush="#334155" Padding="4,2"
                             VerticalContentAlignment="Center" FontSize="11"
                             ToolTip="Intervalo entre tramos afectados (p. ej. 3 = cada tercer tramo)."/>
                    <Border BorderBrush="#334155" BorderThickness="1" CornerRadius="0,4,4,0" Background="#0f172a"
                            Width="26" MinHeight="28" Margin="-1,0,0,0" VerticalAlignment="Stretch">
                      <Grid>
                        <Grid.RowDefinitions>
                          <RowDefinition Height="*"/>
                          <RowDefinition Height="1"/>
                          <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Button x:Name="BtnTroceoAltStepInc" Grid.Row="0"
                                Content="&#x25B2;" FontSize="9" Padding="0,1,0,0" Margin="0"
                                Background="Transparent" BorderThickness="0" Foreground="#94a3b8"
                                VerticalContentAlignment="Center" HorizontalContentAlignment="Center"
                                ToolTip="Más 1"/>
                        <Border Grid.Row="1" Background="#334155" Height="1"/>
                        <Button x:Name="BtnTroceoAltStepDec" Grid.Row="2"
                                Content="&#x25BC;" FontSize="9" Padding="0,0,0,1" Margin="0"
                                Background="Transparent" BorderThickness="0" Foreground="#94a3b8"
                                VerticalContentAlignment="Center" HorizontalContentAlignment="Center"
                                ToolTip="Menos 1"/>
                      </Grid>
                    </Border>
                  </StackPanel>
                </StackPanel>
                <Button x:Name="BtnAlternateSel" Grid.Column="1" Style="{StaticResource BtnSelectOutline}"
                        Content="Alternar referencia en el esquema" FontSize="11" HorizontalAlignment="Stretch"
                        VerticalAlignment="Center" Margin="12,0,0,0" Padding="8,7"
                        ToolTip="Invierte la selección en los tramos del patrón Desde / Cada."/>
              </Grid>
            </Grid>
        </Border>
      </Border>

      <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
        <Button x:Name="BtnCancel" Content="Cancelar" Style="{StaticResource BtnSelectOutline}" MinWidth="110" Margin="0,0,10,0"/>
        <Button x:Name="BtnConfirm" Content="Confirmar troceo" Style="{StaticResource BtnPrimary}" MinWidth="150"/>
      </StackPanel>
    </Grid>
  </Border>
</Window>
